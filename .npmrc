# pnpm hoist patterns — eslint-config-next references plugins by bare name
# (eslint-plugin-react-hooks, eslint-plugin-react, etc.) which fails under
# pnpm's strict node_modules unless they're hoisted to the top level.
# This is the canonical pnpm + eslint-config-next bridge.
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*

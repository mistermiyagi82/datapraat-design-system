    "tailwindcss": "4.2.4",
    "@tailwindcss/postcss": "4.2.4",
    "eslint": "9.39.4",
    "eslint-config-next": "15.5.15",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "prettier": "3.8.3",
